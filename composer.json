{
    "name": "delickate/user-sessions",
    "description": "Laravel package to log user login/logout sessions",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Sani Hyne",
            "email": "delickate@hotmail.com"
        }
    ],
    "require": {
        "php": "^7.3|^8.0|^8.2|^8.3|^8.4",
        "illuminate/contracts": ">=5.6 <13.0"
    },
    "autoload": {
        "psr-4": {
            "Delickate\\UserSessions\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Delickate\\UserSessions\\Providers\\UserSessionsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "php artisan vendor:publish --tag=user-sessions  --force"
        ]
    }
}
